{
  "name": "sidenotesjs",
  "version": "1.0.0",
  "description": "Convert Markdown footnotes into inline sidenotes. No jQuery required.",
  "type": "module",
  "main": "./dist/sidenotes.cjs.js",
  "module": "./dist/sidenotes.esm.js",
  "exports": {
    ".": {
      "import": "./dist/sidenotes.esm.js",
      "require": "./dist/sidenotes.cjs.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node build.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "esbuild": "^0.21.0",
    "jsdom": "^24.0.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT",
  "keywords": [
    "sidenotes",
    "footnotes",
    "markdown",
    "vanilla-js"
  ]
}
